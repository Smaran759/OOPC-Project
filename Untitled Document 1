#include <ncurses.h>

int main() {
    initscr();
    cbreak();
    noecho();
    keypad(stdscr, TRUE);

    mvprintw(0, 0, "Press 'q' to quit");
    refresh();

    int ch;
    while ((ch = getch()) != 'q') {
        mvprintw(2, 0, "You pressed: %c   ", ch);
        refresh();
    }

    endwin();
    return 0;
}
